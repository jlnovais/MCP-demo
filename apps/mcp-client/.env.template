# Copy to .env and fill in your values:
#   cp .env.template .env

# Required — Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional — MCP server endpoint (default: http://127.0.0.1:4000/mcp/v1)
MCP_SERVER_URL=http://127.0.0.1:4000/mcp/v1

# Optional — must match MCP_SERVER_API_KEY on the MCP server
MCP_SERVER_API_KEY=your-mcp-server-api-key

# Optional — Claude model (default: claude-sonnet-5)
CLAUDE_MODEL=claude-sonnet-5

# Optional — max output tokens per response (default: 4096)
CLAUDE_MAX_TOKENS=4096

# Optional — scope guardrail: a cheap pre-check classifies each message as
# in/out of scope and refuses out-of-scope requests before the main turn
# (default: true). Set to false to disable.
SCOPE_CLASSIFIER_ENABLED=true

# Optional — model used for the scope classifier (defaults to CLAUDE_MODEL)
# CLAUDE_CLASSIFIER_MODEL=claude-haiku-4-5

# Claude thinking budget in tokens; set to 0 to disable thinking
# The budget must be ≥ 1024 and less than max_tokens, and the model must support extended thinking (Haiku 4.5 does)
CLAUDE_THINKING_BUDGET=1024

# Optional — sampling parameters (only applied when CLAUDE_THINKING_BUDGET=0)
# When extended thinking is enabled, top_p and top_k are ignored and temperature must be 1
# Claude 4.x models (e.g. claude-haiku-4-5) accept temperature OR top_p, not both — set only one
# CLAUDE_TEMPERATURE=0.7  # Randomness of word choice (0=deterministic, 1=creative); lower for facts/code, higher for brainstorming
# CLAUDE_TOP_P=0.9        # Nucleus sampling: sample from tokens covering this fraction of probability mass; low (e.g. 0.1)=very safe/predictable, high (e.g. 0.95)=more varied
# CLAUDE_TOP_K=40         # Only consider the K most likely next tokens; smaller = safer/more predictable output

# Optional — web client port (default: 3001)
CLIENT_WEB_PORT=3001

# Required for web client — HTTP Basic Auth credentials
CLIENT_WEB_USERNAME=your-username
CLIENT_WEB_PASSWORD=your-password
