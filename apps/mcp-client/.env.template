# Copy to .env and fill in your values:
#   cp .env.template .env

# Required — Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional — MCP server endpoint (default: http://127.0.0.1:4000/mcp/v1)
MCP_SERVER_URL=http://127.0.0.1:4000/mcp/v1

# Optional — must match MCP_SERVER_API_KEY on the MCP server
MCP_SERVER_API_KEY=your-mcp-server-api-key

# Optional — Claude model (default: claude-sonnet-5)
CLAUDE_MODEL=claude-sonnet-5

# Optional — max output tokens per response (default: 4096)
CLAUDE_MAX_TOKENS=4096

# Claude thinking budget in tokens; set to 0 to disable thinking
CLAUDE_THINKING_BUDGET=1024
