{
  "name": "mcp-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo with MCP server (NestJS) and MCP client",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "build": "npm run build --workspaces --if-present",
    "start:server": "npm run start -w @mcp-demo/mcp-server",
    "start:server:dev": "npm run start:dev -w @mcp-demo/mcp-server",
    "start:client": "npm run start -w @mcp-demo/mcp-client"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.18.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.20.0"
  }
}
